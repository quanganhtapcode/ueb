rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOrderOwner() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isCreatingOwnOrder() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function isUpdatingOwnOrder() {
      return isOrderOwner() && request.resource.data.userId == resource.data.userId;
    }

    function isMatchParticipant() {
      return isSignedIn()
        && (
          resource.data.buyUserId == request.auth.uid
          || resource.data.sellUserId == request.auth.uid
        );
    }

    function isChatMember(chatData) {
      return isSignedIn() && request.auth.uid in chatData.participantIds;
    }

    function isMemberOfChat(chatId) {
      return isChatMember(get(/databases/$(database)/documents/chats/$(chatId)).data);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if isCreatingOwnOrder();
      allow update: if isUpdatingOwnOrder();
      allow delete: if isOrderOwner();
    }

    match /matches/{matchId} {
      allow read: if isMatchParticipant();
    }

    match /chats/{chatId} {
      allow read: if isChatMember(resource.data);
      allow create: if isChatMember(request.resource.data);
      allow update, delete: if isChatMember(resource.data) && isChatMember(request.resource.data);
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isMemberOfChat(chatId);
      allow create: if isMemberOfChat(chatId) && request.resource.data.senderUserId == request.auth.uid;
    }
  }
}
